# --- Tokyo Tenders sync layer ---
# Secret used to sign account tokens (any long random string). REQUIRED in production.
TT_TOKEN_SECRET=change-me-to-a-long-random-string

# Persistence. Leave DATABASE_URL empty to use the in-memory store (dev only — data resets on restart).
# For production, point at Postgres/Supabase and run db/schema.sql.
DATABASE_URL=

# Loyalty tuning (safe defaults; override if you want)
TT_POINTS_PER_100_EGGS=10      # points awarded per 100 eggs caught
TT_DAILY_POINT_CAP=30          # max points a player can earn from the game per day
TT_POINTS_PER_DOLLAR=20        # 20 points = $1 off when redeemed
